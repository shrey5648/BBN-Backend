# ==============================================
# Big Breaking News India — Backend Environment
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to Git!

# Server
NODE_ENV=development
PORT=5000

# MySQL Database (Local Development)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bbn_india_db
DB_USER=root
DB_PASS=yourpassword

# JWT Secret (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret_key_in_production
JWT_EXPIRES_IN=7d

# File Upload
UPLOAD_PATH=./src/uploads
MAX_FILE_SIZE=5242880

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ==============================================
# PRODUCTION VALUES (fill before Hostinger deploy)
# ==============================================
# DB_HOST=localhost
# DB_NAME=bbn_india_db      (Hostinger DB name)
# DB_USER=bbn_user          (Hostinger DB user)
# DB_PASS=                  (Hostinger DB password)
# FRONTEND_URL=https://yourdomain.com
